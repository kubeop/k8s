kind: KubeletConfiguration
apiVersion: kubelet.config.k8s.io/v1beta1
{% if kubernetes.ipv4_stack and kubernetes.ipv6_stack %}
address: 0.0.0.0
{% elif kubernetes.ipv4_stack %}
address: 0.0.0.0
{% else %}
address: "::"
{% endif %}
cgroupDriver: systemd
authentication:
  anonymous:
    enabled: false
  webhook:
    enabled: true
    cacheTTL: "2m"
  x509:
    clientCAFile: "/etc/kubernetes/pki/ca.pem"
authorization:
  mode: Webhook
  webhook:
    cacheAuthorizedTTL: "5m"
    cacheUnauthorizedTTL: "30s"
clusterDomain: "cluster.local"
clusterDNS:
{% if nodelocaldns.enabled %}
{% if kubernetes.ipv4_stack and kubernetes.ipv6_stack %}
  - "{{ nodelocaldns.ip }}"
{% elif kubernetes.ipv4_stack %}
  - "{{ nodelocaldns.ip }}"
{% else %}
  - "{{ nodelocaldns.ip6 }}"
{% endif %}
{% else %}
{% if kubernetes.ipv4_stack and kubernetes.ipv6_stack %}
  - "{{ kubernetes.service_addresses | ansible.utils.next_nth_usable(10) }}"
{% elif kubernetes.ipv4_stack %}
  - "{{ kubernetes.service_addresses | ansible.utils.next_nth_usable(10) }}"
{% else %}
  - "{{ kubernetes.service_addresses_ipv6 | ansible.utils.next_nth_usable(10) }}"
{% endif %}
{% endif %}
cpuManagerReconcilePeriod: 10s
maxPods: {{ kubernetes.kubelet.max_pods | default(110) }}
fileCheckFrequency: 20s
httpCheckFrequency: 20s
{% if kubernetes.ipv4_stack and kubernetes.ipv6_stack %}
healthzBindAddress: 0.0.0.0
{% elif kubernetes.ipv4_stack %}
healthzBindAddress: 0.0.0.0
{% else %}
healthzBindAddress: "::"
{% endif %}
healthzPort: 10248
imageMinimumGCAge: 2m
imageGCHighThresholdPercent: 85
imageGCLowThresholdPercent: 80
rotateCertificates: true
runtimeRequestTimeout: 2m
staticPodPath: /etc/kubernetes/manifests
streamingConnectionIdleTimeout: 4h
syncFrequency: 1m
volumeStatsAggPeriod: 1m
{% if kubernetes.version | regex_replace('v') is version("1.28.0","ge") %}
containerRuntimeEndpoint: unix://{{containerd.state}}/containerd.sock
imageServiceEndpoint: unix://{{containerd.state}}/containerd.sock
{% endif %}
{% if ansible_os_family in ['Debian'] %}
resolvConf: /run/systemd/resolve/resolv.conf
{% endif %}
{% if kubernetes.kubelet.extra_flags | length > 0 %}
{{ kubernetes.kubelet.extra_flags | to_nice_yaml(indent=2) }}
{% endif %}
